# ─── Server ───────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000

# ─── PostgreSQL (Docker Core Network Router) ──────────────
PG_DSN=postgresql://grc_user:your_pg_password_here@postgres:5432/grc_copilot

# ─── MongoDB (Docker Core Network Router) ─────────────────
MONGO_URI=mongodb://mongodb:27017/grc_copilot

# ─── Internal auth ────────────────────────────────────────
INTERNAL_SERVICE_KEY=your_internal_gateway_secret_key

# ─── Report output ────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports

# ─── LLM Configuration ────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq