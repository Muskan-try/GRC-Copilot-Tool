# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL (Docker Core Network Router) ──────────────
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=grc_copilot
PG_USER=grc_user
PG_PASSWORD=your_pg_password_here

# ─── MongoDB (Docker Core Network Router) ─────────────────
MONGO_URI=mongodb://mongodb:27017/grc_copilot

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=86400

# ─── FastAPI Analysis Engine (Docker Service Alias) ───────
FASTAPI_URL=http://fastapi-engine:8000

# ─── File Uploads ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Security Configuration ───────────────────────────────
CORS_ORIGIN=*